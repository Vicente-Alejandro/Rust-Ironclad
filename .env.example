# Server
# 0.0.0.0 allows the server to be accessible from any network interface, which is useful for development and testing. In production, you might want to restrict this to a specific IP address or use a reverse proxy.
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
ENVIRONMENT=development

# PostgreSQL
# Note: You must ensure adapt this to your real database credentials and settings. The `statement-cache-capacity` parameter is optional but can improve performance by caching prepared statements. Also consider your traffic patterns and database capabilities when configuring connection pool settings.
DATABASE_URL=postgresql://postgres:password@localhost:5432/template_db?statement-cache-capacity=100
DB_MAX_CONNECTIONS=10
DB_MIN_CONNECTIONS=1
DB_ACQUIRE_TIMEOUT=5
DB_IDLE_TIMEOUT=300

# --- BCRYPT CONFIGURATION ---
# The cost factor determines the hashing complexity (2^cost iterations).
# WARNING: Costs 4, 6, and 8 are INSECURE for production; use only for local testing.
# Standard security baseline is 12. 
# NOTE: If database insertions feel slow, verify this value; higher costs significantly increase CPU load.
BCRYPT_COST=6

# MongoDB (opcional)
# MONGODB_URL=mongodb://localhost:27017
# MONGODB_NAME=template_db

# JWT
JWT_SECRET=thisisasupermegasecretkey-12345
JWT_EXPIRATION=86400
